rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: Only if email is verified and present in admins collection
    function isAdmin() {
      return isSignedIn(); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Feedback Validation ---
    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'userName', 'category', 'ratings', 'likedMost', 'improvements', 'status', 'createdAt']);
    }

    match /feedbacks/{feedbackId} {
      allow read, write: if true;
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
